  "item": [
    {
      "name": "01 - Save Province",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{provinceName}}\",\n  \"code\": \"{{provinceCode}}\",\n  \"type\": \"PROVINCE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/locations/save",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "locations",
            "save"
          ]
        }
      }
    },
    {
      "name": "02 - Get Provinces (capture provinceId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "const p = data.find(x => x.code === pm.environment.get(\"provinceCode\"));",
              "if (p) { pm.environment.set(\"provinceId\", p.id); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/locations/provinces",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "locations",
            "provinces"
          ]
        }
      }
